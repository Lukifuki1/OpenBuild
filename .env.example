# ============================================
# OpenBuild + OpenHands v0.62.0 — Environment
# ============================================
# Kopiraj to datoteko v .env in nastavi vrednosti.
# start.sh bo avtomatsko generiral manjkajoce skrivnosti.
#
# OPOMBA: Ne commitaj .env datoteke v git!
# ============================================

# ---------- LLM konfiguracija ----------
# Qwen3-Coder:30B prek Ollama serverja (fiksno)
# Ollama mora tecati na gostitelju (privzeti port 11434)
LLM_MODEL=ollama/qwen3-coder:30b
LLM_API_KEY=local-key
LLM_BASE_URL=http://host.docker.internal:11434

# Za oblacne ponudnike (ce ne uporabljate Ollama):
# LLM_MODEL=gpt-4o
# LLM_API_KEY=tvoj-api-kljuc
# LLM_BASE_URL=

# ---------- OpenHands konfiguracija ----------
# Runtime sandbox image (ne spreminjaj brez razloga)
SANDBOX_RUNTIME_CONTAINER_IMAGE=docker.openhands.dev/openhands/runtime:0.62-nikolaik

# Workspace pot (privzeto: ./workspace)
WORKSPACE_BASE=./workspace

# Uporabniski ID za sandbox (privzeto: trenutni uporabnik)
# SANDBOX_USER_ID=1000

# Volumni za mount v sandbox (format: host_pot:container_pot[:nacin])
# SANDBOX_VOLUMES=/pot/do/projekta:/workspace:rw

# Logiranje vseh dogodkov (koristno za razhroscevanje)
LOG_ALL_EVENTS=true

# ---------- Omrezje ----------
# Port za OpenHands UI
OPENHANDS_PORT=3000

# ---------- Varnost ----------
# Interni JWT secret (generira se avtomatsko)
JWT_SECRET=

# ---------- GPU (opcijsko) ----------
# Nastavi na true ce zelis uporabiti GPU
ENABLE_GPU=auto
